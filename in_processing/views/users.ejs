<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/header', { title: title }) %>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: radial-gradient(circle at top left, #2b1055, #7597de);
            color: white;
            padding: 40px 20px;
            min-height: 100vh;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #3f4458;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }
        h1 {
            text-align: center;
            margin-bottom: 30px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #555;
        }
        th {
            background-color: #2c3040;
            color: #a88eff;
        }
        tr:hover {
            background-color: rgba(168, 142, 255, 0.1);
        }
        .btn {
            display: inline-block;
            background: #f4f4f4;
            color: #222;
            padding: 10px 20px;
            border-radius: 4px;
            text-decoration: none;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📋 Список пользователей</h1>
        
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Имя</th>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Дата регистрации</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(function(user) { %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.display_name %></td>
                            <td><%= user.username %></td>
                            <td><%= user.email %></td>
                            <td><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" style="text-align: center;">Нет зарегистрированных пользователей</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
        
        <a href="/" class="btn">← Назад к регистрации</a>
    </div>
</body>
</html>