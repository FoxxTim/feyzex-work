<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/header', { title: title }) %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, #2b1055, #7597de);
            color: white;
        }

        .navbar {
            background: rgba(63, 68, 88, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid rgba(168, 142, 255, 0.3);
        }

        .nav-brand {
            font-size: 1.5rem;
            font-weight: bold;
            background: linear-gradient(135deg, #a88eff, #ff6b9d);
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-menu {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .nav-menu a {
            color: #e0e0e0;
            text-decoration: none;
            transition: color 0.3s;
        }

        .nav-menu a:hover {
            color: #a88eff;
        }

        .btn-logout {
            background: linear-gradient(135deg, #ff6b6b, #ff4757);
            color: white;
            padding: 8px 20px;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s;
        }

        .btn-logout:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 71, 87, 0.4);
        }

        .container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .welcome-card {
            background: rgba(63, 68, 88, 0.95);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 20px;
            border: 2px solid rgba(168, 142, 255, 0.3);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: slideUp 0.6s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .user-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .info-card {
            background: rgba(44, 48, 64, 0.8);
            padding: 20px;
            border-radius: 10px;
            border: 1px solid rgba(168, 142, 255, 0.2);
        }

        .info-label {
            color: #a88eff;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 1.2rem;
            font-weight: 600;
        }

        .actions {
            margin-top: 30px;
            display: flex;
            gap: 15px;
        }

        .btn {
            padding: 12px 25px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, #a88eff, #ff6b9d);
            color: white;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(168, 142, 255, 0.4);
        }

        @media (max-width: 600px) {
            .navbar {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
            }
            
            .nav-menu {
                flex-wrap: wrap;
                justify-content: center;
            }
            
            .container {
                margin: 20px auto;
            }
            
            .welcome-card {
                padding: 25px;
            }
            
            h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">⚡ Neon Dashboard</div>
        <div class="nav-menu">
            <a href="/dashboard">Главная</a>
            <a href="/profile">Профиль</a>
            <a href="/users">Пользователи</a>
            <a href="/logout" class="btn-logout">🚪 Выйти</a>
        </div>
    </nav>

    <div class="container">
        <% if (success_msg) { %>
            <div style="background: rgba(76, 175, 80, 0.2); border: 1px solid #4CAF50; color: #81c784; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                ✅ <%= success_msg %>
            </div>
        <% } %>

        <div class="welcome-card">
            <h1>👋 Привет, <%= user.displayName %>!</h1>
            <p style="color: #a0a0a0; font-size: 1.1rem;">Добро пожаловать в ваш личный кабинет</p>
            
            <div class="user-info">
                <div class="info-card">
                    <div class="info-label">Имя</div>
                    <div class="info-value"><%= user.displayName %></div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Логин</div>
                    <div class="info-value"><%= user.username %></div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Email</div>
                    <div class="info-value"><%= user.email %></div>
                </div>
                
                <div class="info-card">
                    <div class="info-label">Статус</div>
                    <div class="info-value">🟢 Онлайн</div>
                </div>
            </div>

            <div class="actions">
                <a href="/profile" class="btn btn-primary">✏️ Редактировать профиль</a>
                <a href="/users" class="btn btn-secondary">👥 Все пользователи</a>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>