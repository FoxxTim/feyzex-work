<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/header', { title: title }) %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at top right, #1a237e, #4a148c, #880e4f);
            background-attachment: fixed;
            background-size: cover;
            color: white;
            position: relative;
            padding: 20px;
            overflow: hidden;
        }

        /* Анимированные частицы */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: float 15s infinite;
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0) translateX(0);
            }
            25% {
                transform: translateY(-100px) translateX(50px);
            }
            50% {
                transform: translateY(-50px) translateX(-30px);
            }
            75% {
                transform: translateY(-150px) translateX(-50px);
            }
        }

        .login-container {
            position: relative;
            z-index: 10;
            background: rgba(63, 68, 88, 0.95);
            backdrop-filter: blur(10px);
            padding: 40px 50px;
            border-radius: 20px;
            width: 100%;
            max-width: 480px;
            box-shadow: 
                0 20px 60px rgba(0, 0, 0, 0.5),
                0 0 30px rgba(168, 142, 255, 0.3);
            border: 2px solid rgba(168, 142, 255, 0.3);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        @keyframes slideUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        h2 {
            text-align: center;
            font-size: 2.2rem;
            margin-bottom: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #a88eff, #ff6b9d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            text-align: center;
            color: #a0a0a0;
            margin-bottom: 30px;
            font-size: 0.95rem;
        }

        .alert {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .alert-success {
            background-color: rgba(76, 175, 80, 0.2);
            border: 1px solid rgba(76, 175, 80, 0.5);
            color: #81c784;
        }

        .alert-danger {
            background-color: rgba(244, 67, 54, 0.2);
            border: 1px solid rgba(244, 67, 54, 0.5);
            color: #e57373;
        }

        .input-group {
            margin-bottom: 25px;
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            color: #a88eff;
            z-index: 1;
        }

        label {
            display: block;
            font-size: 0.9rem;
            color: #b0b0b0;
            margin-bottom: 8px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input {
            width: 100%;
            background-color: rgba(44, 48, 64, 0.8);
            border: 2px solid rgba(168, 142, 255, 0.2);
            border-radius: 10px;
            padding: 14px 15px 14px 45px;
            color: white;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
        }

        input::placeholder {
            color: #6b7280;
        }

        input:focus {
            border-color: #a88eff;
            box-shadow: 
                0 0 20px rgba(168, 142, 255, 0.4),
                inset 0 0 20px rgba(168, 142, 255, 0.1);
            background-color: rgba(53, 58, 77, 0.9);
        }

        input.is-invalid {
            border-color: #ff6b6b;
            box-shadow: 0 0 15px rgba(255, 107, 107, 0.4);
        }

        .forgot-password {
            text-align: right;
            margin-top: -15px;
            margin-bottom: 20px;
        }

        .forgot-password a {
            color: #a88eff;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        .forgot-password a:hover {
            color: #ff6b9d;
            text-decoration: underline;
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, #a88eff, #ff6b9d);
            color: white;
            border: none;
            padding: 14px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(168, 142, 255, 0.4);
            position: relative;
            overflow: hidden;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(168, 142, 255, 0.6);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: 0.5s;
        }

        .btn-submit:hover::before {
            left: 100%;
        }

        .links {
            text-align: center;
            margin-top: 25px;
            color: #a0a0a0;
        }

        .links a {
            color: #a88eff;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s;
        }

        .links a:hover {
            color: #ff6b9d;
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 25px 0;
            color: #6b7280;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(168, 142, 255, 0.2);
        }

        .divider span {
            padding: 0 15px;
            font-size: 0.9rem;
        }

        .social-login {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .social-btn {
            flex: 1;
            padding: 10px;
            border: 2px solid rgba(168, 142, 255, 0.2);
            border-radius: 10px;
            background: transparent;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1.2rem;
        }

        .social-btn:hover {
            background: rgba(168, 142, 255, 0.1);
            border-color: #a88eff;
        }

        @media (max-width: 600px) {
            body {
                padding: 15px;
            }

            .login-container {
                padding: 30px 25px;
                margin: 0;
            }
            
            h2 {
                font-size: 1.8rem;
            }

            input {
                padding: 12px 15px 12px 40px;
            }

            .social-login {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Анимированные частицы -->
    <div class="particles" id="particles"></div>

    <div class="login-container">
        <div class="logo">
            <div class="logo-icon">🔐</div>
        </div>
        
        <h2>Вход в систему</h2>
        <p class="subtitle">Добро пожаловать обратно!</p>
        
        <!-- Flash сообщения об успехе -->
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                ✅ <%= success_msg %>
            </div>
        <% } %>
        
        <!-- Flash сообщения об ошибках -->
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger">
                ❌ <%= error_msg %>
            </div>
        <% } %>
        
        <form action="/login" method="POST" id="loginForm">
            <div class="input-group">
                <label for="login">Логин или Email</label>
                <span class="input-icon">👤</span>
                <input type="text" 
                       id="login" 
                       name="login" 
                       value="<%= formData.login || '' %>"
                       placeholder="username или example@mail.com" 
                       required 
                       autocomplete="username"
                       class="<%= error_msg ? 'is-invalid' : '' %>">
            </div>

            <div class="input-group">
                <label for="password">Пароль</label>
                <span class="input-icon">🔒</span>
                <input type="password" 
                       id="password" 
                       name="password" 
                       placeholder="••••••••" 
                       required
                       class="<%= error_msg ? 'is-invalid' : '' %>">
            </div>

            <div class="forgot-password">
                <a href="/forgot-password">Забыли пароль?</a>
            </div>

            <button type="submit" class="btn-submit" id="submitBtn">
                Войти
            </button>
        </form>

        <div class="divider">
            <span>или</span>
        </div>

        <div class="social-login">
            <button class="social-btn" title="Google">🔵 G</button>
            <button class="social-btn" title="GitHub">🐙 GH</button>
            <button class="social-btn" title="Telegram">✈️ TG</button>
        </div>

        <div class="links">
            <p>Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
        </div>
    </div>

    <script>
        // Создание анимированных частиц
        function createParticles() {
            const container = document.getElementById('particles');
            const colors = ['#a88eff', '#ff6b9d', '#4CAF50', '#FFD700'];
            
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                
                const size = Math.random() * 4 + 2;
                const color = colors[Math.floor(Math.random() * colors.length)];
                
                particle.style.width = size + 'px';
                particle.style.height = size + 'px';
                particle.style.background = color;
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
                
                container.appendChild(particle);
            }
        }

        createParticles();

        // Показать/скрыть пароль (опционально)
        const togglePassword = document.createElement('span');
        togglePassword.innerHTML = '👁️';
        togglePassword.style.cssText = `
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            font-size: 1.2rem;
            z-index: 1;
            user-select: none;
        `;
        
        const passwordField = document.getElementById('password');
        const passwordGroup = passwordField.parentElement;
        passwordGroup.style.position = 'relative';
        passwordGroup.appendChild(togglePassword);

        togglePassword.addEventListener('click', () => {
            const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordField.setAttribute('type', type);
            togglePassword.innerHTML = type === 'password' ? '👁️' : '🙈';
        });
    </script>

    <%- include('partials/footer') %>
</body>
</html>