<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/header', { title: title }) %>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, #2b1055, #7597de);
            color: white;
        }

        .navbar {
            background: rgba(63, 68, 88, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid rgba(168, 142, 255, 0.3);
        }

        .nav-brand {
            font-size: 1.5rem;
            font-weight: bold;
        }

        .nav-menu a {
            color: #e0e0e0;
            text-decoration: none;
            margin-left: 20px;
            transition: color 0.3s;
        }

        .nav-menu a:hover {
            color: #a88eff;
        }

        .container {
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .profile-card {
            background: rgba(63, 68, 88, 0.95);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 20px;
            border: 2px solid rgba(168, 142, 255, 0.3);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .avatar {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #a88eff, #ff6b9d);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin: 0 auto 20px;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">⚡ Neon Profile</div>
        <div class="nav-menu">
            <a href="/dashboard">Главная</a>
            <a href="/profile">Профиль</a>
            <a href="/logout">Выйти</a>
        </div>
    </nav>

    <div class="container">
        <div class="profile-card">
            <div class="avatar"><%= user.displayName.charAt(0).toUpperCase() %></div>
            <h1><%= user.displayName %></h1>
            
            <div style="background: rgba(44, 48, 64, 0.8); padding: 20px; border-radius: 10px; margin-top: 20px;">
                <p><strong>Логин:</strong> @<%= user.username %></p>
                <p><strong>Email:</strong> <%= user.email %></p>
                <p><strong>ID:</strong> #<%= user.id %></p>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>